<!DOCTYPE html>
<html lang="es">

<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Iniciar Sesión — TechCare.mza</title>
  <link rel="stylesheet" href="/css/style.css">
  <link rel="stylesheet" href="/css/responsive.css">
  <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">
</head>

<body>
  <nav class="navbar">
    <a href="/" class="logo">TechCare<span>.mza</span></a>
  </nav>

  <div class="auth-wrapper">
    <div class="auth-box glass-card fade-up">
      <div style="text-align:center; margin-bottom:2rem;">
        <div style="font-size:2.5rem; margin-bottom:0.75rem;"><i class="fa-solid fa-key"></i></div>
        <h2>Bienvenido de vuelta</h2>
        <p class="subtitle">Ingresá para ver el estado de tus dispositivos</p>
      </div>

      <% if (error) { %>
        <div class="error-msg"><i class="fa-solid fa-triangle-exclamation"></i>
          <%= error %>
        </div>
        <% } %>

          <form action="/login" method="POST" id="login-form">
            <div class="form-group">
              <label for="email">Email</label>
              <input type="email" id="email" name="email" class="form-control" placeholder="tu@email.com" required
                autocomplete="email">
            </div>
            <div class="form-group">
              <label for="password">Contraseña</label>
              <input type="password" id="password" name="password" class="form-control" placeholder="••••••••" required
                autocomplete="current-password">
            </div>
            <button type="submit" class="btn" style="width:100%; margin-top:0.5rem;" id="submit-btn">
              Iniciar Sesión
            </button>
          </form>

          <div class="divider">o</div>

          <p style="text-align:center; font-size:0.9rem; color:var(--text-2);">
            ¿No tenés cuenta? <a href="/register" style="color:var(--accent); font-weight:700;">Registrate gratis</a>
          </p>
    </div>
  </div>

  <script src="./js/login.js"></script>
</body>

</html>