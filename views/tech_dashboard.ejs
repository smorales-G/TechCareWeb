<!DOCTYPE html>
<html lang="es">

<head>
  <meta charset="UTF-8">
  <title>Panel Técnico — TechCare.mza</title>
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link
    href="https://fonts.googleapis.com/css2?family=Geist:wght@300;400;500;600;700&family=Space+Mono:wght@400;700&display=swap"
    rel="stylesheet">
  <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">
  <link rel="stylesheet" href="/css/tech-dash.css">
</head>

<body>
  <nav>
    <span class="nav-logo"><i class="fa-solid fa-bolt"></i> TechCare.mza</span>
    <div class="nav-right">
      <span class="badge-tech">[ TÉCNICO ]</span>
      <a href="/logout" class="btn-logout">Salir</a>
    </div>
  </nav>

  <main>
    <h1>Panel de Solicitudes</h1>
    <p class="subtitle">FLUJO_OPTIMIZADO_V2 // <%= new Date().toLocaleDateString('es-AR') %>
    </p>

    <div class="filters">
      <a href="/tech/dashboard" class="filter-pill <%= filter==='all'?'active':'' %>">Todas</a>
      <a href="/tech/dashboard?filter=active" class="filter-pill <%= filter==='active'?'active':'' %>"><i
          class="fa-solid fa-bolt"></i> Activas</a>
      <a href="/tech/dashboard?filter=closed" class="filter-pill <%= filter==='closed'?'active':'' %>"><i
          class="fa-solid fa-check"></i> Cerradas</a>
    </div>

    <div class="cards">
      <% if (!requests || requests.length===0) { %>
        <div class="empty">
          <div class="empty-icon"><i class="fa-regular fa-folder-open"></i></div>
          <p>No hay solicitudes en esta categoría.</p>
        </div>
        <% } %>

          <% requests.forEach(req=> { %>
            <div class="card">
              <div class="card-header">
                <div>
                  <div class="card-title">
                    <%= req.device_type %> — <em style="color:var(--muted);font-style:normal;font-size:.9rem;">
                        <%= req.problem_description?.substring(0,60) %>...
                      </em>
                  </div>
                  <div class="card-meta">Ticket #<%= req.id %> · Cliente: <strong style="color:var(--text)">
                        <%= req.client_name %>
                      </strong> · <%= new Date(req.created_at).toLocaleDateString('es-AR') %>
                  </div>
                  <% if (req.estimatedTime) { %><span class="eta"><i class="fa-solid fa-stopwatch"></i>
                      <%= req.estimatedTime %>
                    </span>
                    <% } %>
                </div>
                <span class="status s-<%= req.status %>">
                  <%= req.status.replace(/_/g,' ') %></span>
      </div>

      <div class="card-body">
        <p class="card-desc"><%= req.problem_description %></p>

        <% if (req.media && req.media.length > 0) { %>
        <div class="media-grid">
          <% req.media.forEach(m => { if(m.file_type?.startsWith(' image')) { %>
                    <img src="<%= m.file_url %>" class="media-thumb" alt="Media">
                    <% } }) %>
              </div>
              <% } %>

                <% if (req.lastMsg) { %>
                  <div class="last-msg">
                    <strong><i class="fa-solid fa-message"></i> Último mensaje — <%= req.lastMsg.sender_role %></strong>
                    <%= req.lastMsg.content?.substring(0,120) %>
                      <%= req.lastMsg.content?.length> 120 ? '...' : '' %>
                  </div>
                  <% } %>

                    <!-- ===== ACCIONES POR ESTADO ===== -->

                    <% if (req.status==='pendiente' ) { %>
                      <div class="action-panel">
                        <div class="action-title">Paso 1 — Revisión de Solicitud</div>
                        <div class="action-grid">
                          <form method="POST" action="/tech/request/<%= req.id %>/accept">
                            <div class="field"><label>Mensaje al aceptar</label>
                              <textarea name="tech_response"
                                placeholder="Ej: Hola, recibí tu solicitud. ¿El equipo enciende?" required></textarea>
                            </div>
                            <button type="submit" class="btn btn-green btn-full"><i class="fa-solid fa-check"></i>
                              Aceptar — Iniciar revisión</button>
                          </form>
                          <form method="POST" action="/tech/request/<%= req.id %>/cancel">
                            <div class="field"><label>Motivo de cancelación</label>
                              <textarea name="tech_response"
                                placeholder="Ej: No podemos atender este tipo de dispositivo."></textarea>
                            </div>
                            <button type="submit" class="btn btn-red btn-full"><i class="fa-solid fa-xmark"></i>
                              Cancelar solicitud</button>
                          </form>
                        </div>
                      </div>
                      <% } %>

                        <% if (req.status==='en_revision' ) { %>
                          <div class="action-panel">
                            <div class="action-title">Paso 2 — Coordinar Ingreso del Dispositivo</div>
                            <div class="field"><label>Mensaje de coordinación</label>
                              <form method="POST" action="/tech/request/<%= req.id %>/coordinate"
                                style="display:flex;gap:.75rem;align-items:flex-end">
                                <div style="flex:1"><textarea name="notes"
                                    placeholder="Ej: Podés traer el equipo al taller de lunes a viernes de 9 a 18hs. Dirección: Av. San Martín 1200."></textarea>
                                </div>
                                <button type="submit" class="btn btn-blue" style="height:80px"><i
                                    class="fa-regular fa-calendar-check"></i> Confirmar coordinación</button>
                              </form>
                            </div>
                          </div>
                          <% } %>

                            <% if (req.status==='en_coordinacion' ) { %>
                              <div class="action-panel">
                                <div class="action-title">Paso 3 — Recepción del Dispositivo</div>
                                <div class="action-grid">
                                  <form method="POST" action="/tech/request/<%= req.id %>/arrived">
                                    <div class="field"><label>Estado físico al recibir</label>
                                      <textarea name="notes"
                                        placeholder="Ej: Dispositivo recibido. Presenta grietas en pantalla, teclado ok, sin cargador."></textarea>
                                    </div>
                                    <button type="submit" class="btn btn-green btn-full"><i
                                        class="fa-solid fa-box-open"></i> Dispositivo Recibido</button>
                                  </form>
                                  <form method="POST" action="/tech/request/<%= req.id %>/not-received">
                                    <div class="field"><label>Motivo</label>
                                      <textarea name="notes"
                                        placeholder="Ej: El cliente no se presentó en la fecha acordada."></textarea>
                                    </div>
                                    <button type="submit" class="btn btn-red btn-full"><i class="fa-solid fa-ban"></i>
                                      No Recibido / Cancelar</button>
                                  </form>
                                </div>
                              </div>
                              <% } %>

                                <% if (req.status==='en_recepcion' ) { %>
                                  <div class="action-panel">
                                    <div class="action-title">Paso 4 — Iniciar Diagnóstico Técnico</div>
                                    <div class="action-grid single">
                                      <form method="POST" action="/tech/request/<%= req.id %>/start-diagnosis">
                                        <div class="field"><label>Notas del triage físico</label>
                                          <textarea name="notes"
                                            placeholder="Ej: Equipo en buen estado externo. Iniciando diagnóstico interno."></textarea>
                                        </div>
                                        <button type="submit" class="btn btn-purple btn-full"><i
                                            class="fa-solid fa-microscope"></i> Iniciar Diagnóstico</button>
                                      </form>
                                    </div>
                                  </div>
                                  <% } %>

                                    <% if (req.status==='en_diagnostico' ) { %>
                                      <div class="action-panel">
                                        <div class="action-title">Paso 5 — Informe de Diagnóstico y Presupuesto</div>
                                        <form method="POST" action="/tech/request/<%= req.id %>/diagnosis">
                                          <div class="field-row">
                                            <div class="field"><label>Precio de reparación ($)</label>
                                              <input type="number" name="price" placeholder="Ej: 18000" min="0"
                                                step="100" required style="min-height:auto">
                                            </div>
                                            <div class="field"><label>Notas adicionales</label>
                                              <input type="text" name="notes" placeholder="Opcional"
                                                style="min-height:auto">
                                            </div>
                                          </div>
                                          <div class="field"><label>Informe técnico del diagnóstico</label>
                                            <textarea name="diagnosis" rows="3"
                                              placeholder="Ej: Pantalla OLED dañada por impacto. Táctil con falla en zona superior. Recomiendo cambio de módulo completo."
                                              required style="min-height:100px"></textarea>
                                          </div>
                                          <button type="submit" class="btn btn-purple btn-full"><i
                                              class="fa-solid fa-clipboard-list"></i> Enviar diagnóstico al
                                            cliente</button>
                                        </form>
                                      </div>
                                      <% } %>

                                        <% if (req.status==='esperando_aprobacion' ) { %>
                                          <div class="action-panel" style="border-color:rgba(255,193,7,.3)">
                                            <div class="action-title" style="color:#ffc107">Esperando decisión del
                                              cliente</div>
                                            <% if (req.diagnosis) { %>
                                              <p style="color:var(--muted);font-size:.85rem;margin-bottom:.75rem">
                                                <strong style="color:var(--text)">Diagnóstico:</strong>
                                                <%= req.diagnosis %>
                                              </p>
                                              <% } %>
                                                <% if (req.price) { %>
                                                  <p
                                                    style="font-family:var(--mono);font-size:1rem;color:var(--green);margin-bottom:1rem">
                                                    Presupuesto: $<%= parseFloat(req.price).toLocaleString('es-AR') %>
                                                  </p>
                                                  <% } %>
                                                    <p style="color:var(--muted);font-size:.8rem">El cliente debe
                                                      aceptar o rechazar el presupuesto desde su panel.</p>
                                          </div>
                                          <% } %>

                                            <% if (req.status==='en_reparacion' ) { %>
                                              <div class="action-panel">
                                                <div class="action-title">Paso 7 — En Reparación</div>
                                                <div class="action-grid">
                                                  <form method="POST"
                                                    action="/tech/request/<%= req.id %>/waiting-parts">
                                                    <div class="field"><label>Motivo de espera</label>
                                                      <textarea name="notes"
                                                        placeholder="Ej: Esperando componente X desde proveedor. ETA 3 días."></textarea>
                                                    </div>
                                                    <button type="submit" class="btn btn-amber btn-full"><i
                                                        class="fa-solid fa-hourglass-half"></i> Esperando
                                                      repuestos</button>
                                                  </form>
                                                  <form method="POST" action="/tech/request/<%= req.id %>/repaired">
                                                    <div class="field"><label>Notas de control de calidad</label>
                                                      <textarea name="notes"
                                                        placeholder="Ej: Módulo reemplazado. Testeado 30 min. Funciona correctamente."></textarea>
                                                    </div>
                                                    <button type="submit" class="btn btn-green btn-full"><i
                                                        class="fa-solid fa-check"></i> Reparación completa — Listo para
                                                      retirar</button>
                                                  </form>
                                                </div>
                                              </div>
                                              <% } %>

                                                <% if (req.status==='esperando_repuestos' ) { %>
                                                  <div class="action-panel">
                                                    <div class="action-title">Sub-estado — Esperando Repuestos</div>
                                                    <form method="POST" action="/tech/request/<%= req.id %>/repaired">
                                                      <div class="field"><label>Notas finales</label>
                                                        <textarea name="notes"
                                                          placeholder="Ej: Repuesto llegó. Instalado y testeado. Listo para retiro."></textarea>
                                                      </div>
                                                      <button type="submit" class="btn btn-green btn-full"><i
                                                          class="fa-solid fa-check"></i> Repuesto instalado — Listo para
                                                        retirar</button>
                                                    </form>
                                                  </div>
                                                  <% } %>

                                                    <% if (req.status==='listo_para_retiro' ) { %>
                                                      <div class="action-panel" style="border-color:rgba(0,230,118,.3)">
                                                        <div class="action-title" style="color:var(--green)">Paso 9 —
                                                          Confirmar Entrega</div>
                                                        <form method="POST"
                                                          action="/tech/request/<%= req.id %>/delivered">
                                                          <div class="field"><label>Notas de cierre</label>
                                                            <textarea name="notes"
                                                              placeholder="Ej: Dispositivo entregado. Cliente conforme. Pago cobrado."></textarea>
                                                          </div>
                                                          <button type="submit" class="btn btn-primary btn-full"><i
                                                              class="fa-solid fa-party-horn"></i> Confirmar entrega —
                                                            Cerrar servicio</button>
                                                        </form>
                                                      </div>
                                                      <% } %>

                                                        <% if
                                                          (['completado','cancelado','cancelado_por_tecnico','producto_no_recibido','finalizado'].includes(req.status))
                                                          { %>
                                                          <div class="action-panel" style="opacity:.6">
                                                            <div class="action-title" style="color:var(--muted)">
                                                              Servicio cerrado</div>
                                                            <p style="color:var(--muted);font-size:.85rem">
                                                              <% if (req.status==='completado' ||
                                                                req.status==='finalizado' ) { %><i
                                                                  class="fa-solid fa-check"></i> Servicio completado
                                                                exitosamente.
                                                                <% } else { %><i class="fa-solid fa-xmark"></i> Servicio
                                                                  cancelado.<% } %>
                                                            </p>
                                                          </div>
                                                          <% } %>
            </div>
    </div>
    <% }) %>
      </div>
  </main>
</body>

</html>