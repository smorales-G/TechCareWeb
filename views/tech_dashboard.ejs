<!DOCTYPE html>
<html lang="es">
<head>
  <meta charset="UTF-8">
  <title>Tech Dashboard - TechCare.mza</title>
  <link rel="stylesheet" href="/css/style.css">
</head>
<body>
  <nav class="navbar">
    <a href="/" class="logo">TechCare<span>.mza</span> <small style="color:#ef4444; font-size:0.8rem;">[Tech Panel]</small></a>
    <div class="nav-links">
      <span style="color: var(--text-muted); margin-right: 20px;">Técnico: <%= user.username %></span>
      <a href="/logout" class="btn btn-secondary">Cerrar Sesión</a>
    </div>
  </nav>

  <div class="container">
    <h2 style="margin-bottom: 2rem;">Gestión de Solicitudes</h2>

    <div class="grid">
      <% if (requests.length === 0) { %>
        <p style="color: var(--text-muted);">No hay solicitudes en el sistema.</p>
      <% } else { %>
        <% requests.forEach(r => { %>
          <div class="glass-card">
            <div style="display: flex; justify-content: space-between; align-items: start; margin-bottom: 1rem;">
              <h3 style="color: #fff; font-size: 1.1rem;"><%= r.title %></h3>
              <span class="badge <%= r.status %>"><%= r.status.replace(/_/g, ' ') %></span>
            </div>
            
            <p style="color: var(--accent-color); font-size: 0.9rem; margin-bottom: 0.5rem;">
              Cliente: <%= r.client_name %>
            </p>
            
            <div style="background: rgba(0,0,0,0.2); padding: 0.75rem; border-radius: 8px; margin-bottom: 1rem;">
              <p style="color: var(--text-muted); font-size: 0.9rem;"><%= r.description %></p>
              <% if (r.additional_info) { %>
                <hr style="border: 0; border-top: 1px solid var(--glass-border); margin: 0.5rem 0;">
                <p style="color: #94a3b8; font-size: 0.8rem;"><strong>Info Extra:</strong> <%= r.additional_info %></p>
              <% } %>
            </div>

            <form action="/tech/request/<%= r.id %>/status" method="POST">
              <div class="form-group" style="margin-bottom: 0.5rem;">
                <label style="font-size: 0.85rem;">Estado</label>
                <select name="status" class="form-control" style="padding: 0.5rem;">
                  <option value="pendiente" <%= r.status === 'pendiente' ? 'selected' : '' %>>Pendiente</option>
                  <option value="en_revision" <%= r.status === 'en_revision' ? 'selected' : '' %>>En Revisión</option>
                  <option value="consulta_denegada" <%= r.status === 'consulta_denegada' ? 'selected' : '' %>>Consulta Denegada</option>
                  <option value="en_diagnostico" <%= r.status === 'en_diagnostico' ? 'selected' : '' %>>En Diagnóstico</option>
                  <option value="reparacion_aceptada" <%= r.status === 'reparacion_aceptada' ? 'selected' : '' %>>Reparación Aceptada</option>
                  <option value="en_proceso_de_devolucion" <%= r.status === 'en_proceso_de_devolucion' ? 'selected' : '' %>>En Proceso de Devolución</option>
                  <option value="reparacion_completa" <%= r.status === 'reparacion_completa' ? 'selected' : '' %>>Reparación Completa</option>
                  <option value="finalizado" <%= r.status === 'finalizado' ? 'selected' : '' %>>Finalizado</option>
                </select>
              </div>

              <div class="form-group" style="margin-bottom: 0.5rem;">
                <label style="font-size: 0.85rem;">Diagnóstico</label>
                <textarea name="diagnosis" class="form-control" rows="2" placeholder="Detalle del diagnóstico..."><%= r.diagnosis || '' %></textarea>
              </div>

              <div class="form-group" style="margin-bottom: 1rem;">
                <label style="font-size: 0.85rem;">Precio ($)</label>
                <input type="number" step="0.01" name="price" class="form-control" value="<%= r.price || '' %>" placeholder="0.00">
              </div>

              <div class="form-group" style="margin-bottom: 1rem;">
                <label style="font-size: 0.85rem;">Notas para el Historial</label>
                <input type="text" name="notes" class="form-control" placeholder="Ej: Se coordinó entrega por teléfono">
              </div>

              <button type="submit" class="btn btn-secondary" style="width: 100%; font-size: 0.9rem;">Actualizar Estado</button>
            </form>
          </div>
        <% }) %>
      <% } %>
    </div>
  </div>
</body>
</html>
