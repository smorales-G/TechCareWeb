<!DOCTYPE html>
<html lang="es">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Mis Solicitudes — TechCare.mza</title>
  <link rel="stylesheet" href="/css/style.css">
</head>
<body>
  <nav class="navbar">
    <a href="/" class="logo">TechCare<span>.mza</span></a>
    <div class="nav-links">
      <% if (user.profile_picture) { %>
        <img src="<%= user.profile_picture %>" class="avatar" alt="<%= user.username %>" title="<%= user.username %>">
      <% } else { %>
        <div class="avatar-placeholder" title="<%= user.username %>"><%= user.username.charAt(0).toUpperCase() %></div>
      <% } %>
      <span style="color:var(--text-2); font-size:0.9rem;">Hola, <strong style="color:var(--text)"><%= user.username %></strong></span>
      <a href="/logout" class="btn btn-secondary btn-sm">Salir</a>
    </div>
  </nav>

  <div class="container">
    <div class="page-header">
      <div>
        <h2>Mis Solicitudes</h2>
        <p style="color:var(--text-2); font-size:0.9rem; margin-top:0.25rem;">Estado de tus reparaciones y consultas</p>
      </div>
      <a href="/client/request/new" class="btn">+ Nueva Solicitud</a>
    </div>

    <% if (requests.length === 0) { %>
      <div class="empty-state glass-card">
        <span class="empty-icon">🛠️</span>
        <h3>Sin solicitudes todavía</h3>
        <p>Creá tu primera solicitud describiendo el problema de tu dispositivo.</p>
        <a href="/client/request/new" class="btn" style="margin-top:1.5rem;">Crear solicitud</a>
      </div>
    <% } else { %>
      <div class="grid">
        <% requests.forEach(r => { %>
          <div class="request-card">
            <div class="request-card-header">
              <h3><%= r.title %></h3>
              <span class="badge <%= r.status %>"><%= r.status.replace(/_/g, ' ') %></span>
            </div>

            <p class="desc"><%= r.description.length > 100 ? r.description.substring(0, 100) + '...' : r.description %></p>

            <% if (r.status === 'en_diagnostico' && r.diagnosis) { %>
              <div class="diagnosis-box">
                <p><strong>🔍 Diagnóstico:</strong> <%= r.diagnosis %></p>
                <% if (r.price) { %><p style="margin-top:0.5rem;"><strong>💰 Precio:</strong> $<%= Number(r.price).toLocaleString('es-AR') %></p><% } %>
              </div>
              <div class="action-btns">
                <form action="/client/request/<%= r.id %>/action" method="POST" style="flex:1;">
                  <button type="submit" name="action" value="accept" class="btn btn-success" style="width:100%;">✅ Aceptar</button>
                </form>
                <form action="/client/request/<%= r.id %>/action" method="POST" style="flex:1;">
                  <button type="submit" name="action" value="decline" class="btn btn-danger" style="width:100%;">❌ Rechazar</button>
                </form>
              </div>
            <% } %>

            <div class="request-card-footer">
              <span>📅 <%= new Date(r.created_at).toLocaleDateString('es-AR', {day:'2-digit', month:'short', year:'numeric'}) %></span>
              <a href="/client/request/<%= r.id %>" style="color:var(--accent); font-size:0.85rem; font-weight:600; text-decoration:none;">Ver historial →</a>
            </div>
          </div>
        <% }) %>
      </div>
    <% } %>
  </div>
</body>
</html>
