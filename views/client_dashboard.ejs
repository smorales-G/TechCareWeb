<!DOCTYPE html>
<html lang="es">
<head>
  <meta charset="UTF-8">
  <title>Mis Solicitudes — TechCare.mza</title>
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link href="https://fonts.googleapis.com/css2?family=Geist:wght@300;400;500;600;700&family=Space+Mono:wght@400;700&display=swap" rel="stylesheet">
  <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">
  <link rel="stylesheet" href="/css/client-dash.css">
</head>
<body>
<nav>
  <span class="nav-logo"><i class="fa-solid fa-bolt"></i> TechCare.mza</span>
  <div class="nav-right">
    <a href="/client/request/new" class="btn-new"><i class="fa-solid fa-plus"></i> Nueva Solicitud</a>

    <!-- Profile Avatar Dropdown -->
    <div class="profile-menu" id="profileMenu">
      <button class="profile-trigger" id="profileTrigger" onclick="toggleProfileMenu()" aria-haspopup="true" aria-expanded="false">
        <div class="avatar-circle">
          <%= user && user.name ? user.name.charAt(0).toUpperCase() : user && user.username ? user.username.charAt(0).toUpperCase() : 'U' %>
        </div>
        <span class="profile-name"><%= user && user.name ? user.name.split(' ')[0] : user && user.username ? user.username : 'Usuario' %></span>
        <i class="fa-solid fa-chevron-down chevron-icon" id="profileChevron"></i>
      </button>
      <div class="profile-dropdown" id="profileDropdown">
        <div class="dropdown-header">
          <div class="dh-avatar">
            <%= user && user.name ? user.name.charAt(0).toUpperCase() : user && user.username ? user.username.charAt(0).toUpperCase() : 'U' %>
          </div>
          <div>
            <div class="dh-name"><%= user && user.name ? user.name : user && user.username ? user.username : 'Usuario' %></div>
            <div class="dh-email"><%= user && user.email ? user.email : '' %></div>
          </div>
        </div>
        <div class="dropdown-divider"></div>
        <a href="/client/profile" class="dropdown-item">
          <i class="fa-solid fa-user"></i> Mi Perfil
        </a>
        <a href="/client/settings" class="dropdown-item">
          <i class="fa-solid fa-gear"></i> Configuración
        </a>
        <div class="dropdown-divider"></div>
        <a href="/logout" class="dropdown-item dropdown-item--danger">
          <i class="fa-solid fa-right-from-bracket"></i> Cerrar Sesión
        </a>
      </div>
    </div>

  </div>
</nav>

<main>
  <h1>Mis Solicitudes</h1>
  <p class="subtitle">PANEL_CLIENTE // <%= new Date().toLocaleDateString('es-AR') %></p>

  <div class="cards">
    <% if (!requests || requests.length === 0) { %>
    <div class="empty">
      <div class="empty-icon"><i class="fa-solid fa-clipboard-list"></i></div>
      <p>No tenés solicitudes todavía.</p>
      <a href="/client/request/new" class="btn btn-detail" style="margin-top:1rem;display:inline-flex"><i class="fa-solid fa-plus"></i> Crear tu primera solicitud</a>
    </div>
    <% } %>

    <% requests.forEach(req => {
      const ORDER = ['pendiente','en_revision','en_coordinacion','en_recepcion','en_diagnostico','esperando_aprobacion','en_reparacion','esperando_repuestos','listo_para_retiro','completado'];
      const idx = ORDER.indexOf(req.status);
      const pct = idx < 0 ? 0 : Math.round((idx / (ORDER.length - 1)) * 100);
      const needsAction = ['esperando_aprobacion','esperando_respuesta_cliente'].includes(req.status);
      const isClosed = ['completado','cancelado','cancelado_por_tecnico','finalizado','producto_no_recibido'].includes(req.status);
    %>
    <div class="card" style="<%= needsAction ? 'border-color:rgba(255,193,7,.35)' : '' %>">
      <div class="card-header">
        <div>
          <div class="card-title"><%= req.device_type %></div>
          <div class="card-meta">Ticket #<%= req.id %> · <%= new Date(req.created_at).toLocaleDateString('es-AR') %></div>
        </div>
        <span class="status s-<%= req.status %>"><%= req.status.replace(/_/g,' ') %></span>
      </div>
      <div class="card-body">

        <% if (!isClosed) { %>
        <div class="progress-wrap">
          <div class="progress-bar"><div class="progress-fill" style="width:<%= pct %>%"></div></div>
          <div class="progress-label">Paso <%= Math.max(1,idx+1) %> de 9 — <%= req.status.replace(/_/g,' ') %></div>
        </div>
        <% } %>

        <% if (needsAction) { %>
        <div class="notify">
          <i class="fa-solid fa-triangle-exclamation"></i> <strong>Acción requerida:</strong> El técnico cargó el diagnóstico. Revisá el presupuesto.
        </div>
        <% } %>

        <% if (req.status === 'listo_para_retiro') { %>
        <div class="notify" style="background:rgba(0,230,118,.08);border-color:rgba(0,230,118,.3);color:var(--green)">
          <i class="fa-solid fa-champagne-glasses"></i> <strong>¡Tu equipo está listo!</strong> Podés pasar a retirarlo al taller.
        </div>
        <% } %>

        <p class="desc"><%= req.problem_description?.substring(0,120) %><%= req.problem_description?.length > 120 ? '...' : '' %></p>

        <% if (req.tech_response) { %>
        <div class="last-msg">
          <strong><i class="fa-solid fa-message"></i> TÉCNICO</strong><%= req.tech_response?.substring(0,100) %>...
        </div>
        <% } %>

        <div class="btn-actions">
          <a href="/client/request/<%= req.id %>" class="btn btn-detail"><i class="fa-solid fa-eye"></i> Ver detalle y chat</a>

          <% if (needsAction) { %>
          <form method="POST" action="/client/request/<%= req.id %>/action" style="display:inline">
            <input type="hidden" name="action" value="accept">
            <button type="submit" class="btn btn-accept"><i class="fa-solid fa-check"></i> Aceptar presupuesto</button>
          </form>
          <form method="POST" action="/client/request/<%= req.id %>/action" style="display:inline">
            <input type="hidden" name="action" value="reject">
            <button type="submit" class="btn btn-reject"><i class="fa-solid fa-xmark"></i> Rechazar</button>
          </form>
          <% } %>
        </div>
      </div>
    </div>
    <% }) %>
  </div>
</main>

<script>
  function toggleProfileMenu() {
    const dropdown = document.getElementById('profileDropdown');
    const chevron  = document.getElementById('profileChevron');
    const trigger  = document.getElementById('profileTrigger');
    const isOpen   = dropdown.classList.contains('open');
    dropdown.classList.toggle('open');
    chevron.style.transform = isOpen ? 'rotate(0deg)' : 'rotate(180deg)';
    trigger.setAttribute('aria-expanded', !isOpen);
  }
  // Close on outside click
  document.addEventListener('click', function(e) {
    const menu = document.getElementById('profileMenu');
    if (!menu.contains(e.target)) {
      document.getElementById('profileDropdown').classList.remove('open');
      document.getElementById('profileChevron').style.transform = 'rotate(0deg)';
      document.getElementById('profileTrigger').setAttribute('aria-expanded', 'false');
    }
  });
</script>
</body>
</html>
