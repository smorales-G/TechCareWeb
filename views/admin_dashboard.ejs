<!DOCTYPE html>
<html lang="es">
<head>
  <meta charset="UTF-8">
  <title>Admin Dashboard - TechCare.mza</title>
  <link rel="stylesheet" href="/css/style.css">
</head>
<body>
  <nav class="navbar">
    <a href="/" class="logo">TechCare<span>.mza</span> <small style="color:#a855f7; font-size:0.8rem;">[Admin Panel]</small></a>
    <div class="nav-links">
      <span style="color: var(--text-muted); margin-right: 20px;">Admin: <%= user.username %></span>
      <a href="/logout" class="btn btn-secondary">Cerrar Sesión</a>
    </div>
  </nav>

  <div class="container">
    <h2 style="margin-bottom: 2rem;">Gestión de Usuarios</h2>

    <div class="glass-card" style="padding: 0; overflow: hidden;">
      <table style="width: 100%; border-collapse: collapse; text-align: left;">
        <thead style="background: rgba(0,0,0,0.3);">
          <tr>
            <th style="padding: 1rem; color: var(--text-muted);">ID</th>
            <th style="padding: 1rem; color: var(--text-muted);">Usuario</th>
            <th style="padding: 1rem; color: var(--text-muted);">Email</th>
            <th style="padding: 1rem; color: var(--text-muted);">Rol</th>
            <th style="padding: 1rem; color: var(--text-muted);">Acciones</th>
          </tr>
        </thead>
        <tbody>
          <% if (users.length === 0) { %>
            <tr>
              <td colspan="5" style="padding: 1rem; text-align: center; color: var(--text-muted);">No hay usuarios registrados.</td>
            </tr>
          <% } else { %>
            <% users.forEach(u => { %>
              <tr style="border-bottom: 1px solid var(--glass-border);">
                <td style="padding: 1rem;"><%= u.id %></td>
                <td style="padding: 1rem;"><%= u.username %></td>
                <td style="padding: 1rem;"><%= u.email %></td>
                <td style="padding: 1rem;">
                  <span class="badge" style="
                    background: <%= u.role === 'admin' ? '#a855f7' : (u.role === 'technician' ? '#ef4444' : '#3b82f6') %>;
                    color: white;
                  "><%= u.role.toUpperCase() %></span>
                </td>
                <td style="padding: 1rem;">
                  <form action="/admin/user/<%= u.id %>/role" method="POST" style="display: flex; gap: 10px;">
                    <select name="role" class="form-control" style="padding: 0.5rem; min-width: 120px;">
                      <option value="client" <%= u.role === 'client' ? 'selected' : '' %>>Client</option>
                      <option value="technician" <%= u.role === 'technician' ? 'selected' : '' %>>Technician</option>
                      <option value="admin" <%= u.role === 'admin' ? 'selected' : '' %>>Admin</option>
                    </select>
                    <button type="submit" class="btn" style="padding: 0.5rem 1rem;">Guardar</button>
                  </form>
                </td>
              </tr>
            <% }) %>
          <% } %>
        </tbody>
      </table>
    </div>
  </div>
</body>
</html>
