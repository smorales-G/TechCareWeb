<!DOCTYPE html>
<html lang="es">

<head>
  <meta charset="UTF-8">
  <title>Detalle de Solicitud — TechCare.mza</title>
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link
    href="https://fonts.googleapis.com/css2?family=Geist:wght@300;400;500;600;700&family=Space+Mono:wght@400;700&display=swap"
    rel="stylesheet">
  <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">
  <link rel="stylesheet" href="/css/request-detail.css">
</head>

<body>
  <nav>
    <span class="nav-logo"><i class="fa-solid fa-bolt"></i> TechCare.mza</span>
    <a href="/client/dashboard" class="btn-back">← Volver</a>
  </nav>

  <main>
    <div class="page-header">
      <div>
        <h1 class="page-title">Solicitud #<%= request.id %>
        </h1>
        <p class="page-sub">DISPOSITIVO_ID:<%= request.id %> // CREADO <%= new
              Date(request.created_at).toLocaleDateString('es-AR') %>
        </p>
      </div>
      <span class="status s-<%= request.status %>">
        <%= request.status.replace(/_/g,' ') %></span>
  </div>

  <div class="layout">
    <!-- COLUMNA IZQUIERDA -->
    <div>
      <!-- Info del dispositivo -->
      <div class="card">
        <div class="card-head">Información del dispositivo</div>
        <div class="card-body">
          <div class="info-grid">
            <div class="info-item"><label>Tipo de dispositivo</label><p><%= request.device_type || ' —' %>
          </p>
    </div>
    <div class="info-item"><label>Estado</label><span class="status s-<%= request.status %>">
        <%= request.status.replace(/_/g,' ') %></span></div>
          </div>
          <div class="desc-box"><%= request.problem_description %></div>
          <% if (media && media.length > 0) { %>
          <div class="media-row" style="margin-top:.75rem">
            <% media.forEach(m => { if(m.file_type?.startsWith('image')) { %>
          <img src="<%= m.file_url %>" class="media-thumb" alt="Media">
          <% } }) %>
    </div>
    <% } %>
      </div>
      </div>

      <!-- Respuesta del técnico -->
      <% if (request.tech_response) { %>
        <div class="card">
          <div class="card-head">Mensaje del técnico</div>
          <div class="card-body">
            <div class="tech-msg-box">
              <div class="tech-msg-label"><i class="fa-solid fa-wrench"></i> TÉCNICO</div>
              <p>
                <%= request.tech_response %>
              </p>
            </div>
          </div>
        </div>
        <% } %>

          <!-- Diagnóstico + decisión -->
          <% if (['esperando_aprobacion','esperando_respuesta_cliente'].includes(request.status)) { %>
            <div class="card" style="border-color:rgba(255,193,7,.3)">
              <div class="card-head" style="color:#ffc107"><i class="fa-solid fa-clipboard-list"></i> Diagnóstico
                técnico — Decisión requerida</div>
              <div class="card-body">
                <% if (request.diagnosis) { %>
                  <div class="diag-box">
                    <p>
                      <%= request.diagnosis %>
                    </p>
                  </div>
                  <% } %>
                    <% if (request.price) { %>
                      <label style="font-family:var(--mono);font-size:.65rem;color:var(--muted)">PRESUPUESTO DE
                        REPARACIÓN</label>
                      <div class="price-big">$<%= parseFloat(request.price).toLocaleString('es-AR') %>
                      </div>
                      <% } %>
                        <div class="decision-btns">
                          <form method="POST" action="/client/request/<%= request.id %>/action">
                            <input type="hidden" name="action" value="accept">
                            <button type="submit" class="btn btn-accept" style="width:100%"><i
                                class="fa-solid fa-check"></i> Aceptar reparación</button>
                          </form>
                          <form method="POST" action="/client/request/<%= request.id %>/action">
                            <input type="hidden" name="action" value="reject">
                            <button type="submit" class="btn btn-reject" style="width:100%"><i
                                class="fa-solid fa-xmark"></i> Rechazar presupuesto</button>
                          </form>
                        </div>
              </div>
            </div>
            <% } %>

              <!-- Chat -->
              <div class="card">
                <div class="card-head">Chat del servicio</div>
                <div class="card-body">
                  <div class="chat-window">
                    <div class="chat-msgs" id="chatMsgs">
                      <% if (!messages || messages.length===0) { %>
                        <div style="text-align:center;color:var(--muted);font-size:.8rem;padding:2rem 0">No hay mensajes
                          aún. Iniciá la conversación.</div>
                        <% } %>
                          <% (messages || []).forEach(m=> { %>
                            <div class="msg <%= m.sender_role %>">
                              <div class="msg-name">
                                <%= m.sender_role==='bot' ? '<i class="fa-solid fa-robot"></i> BOT' :
                                  m.sender_name?.toUpperCase() %>
                              </div>
                              <%= m.content %>
                            </div>
                            <% }) %>
                    </div>
                    <form class="chat-form" id="chatForm">
                      <input type="text" class="chat-input" id="chatInput" placeholder="Escribí tu mensaje..."
                        autocomplete="off">
                      <button type="submit" class="chat-send"><i class="fa-solid fa-paper-plane"></i></button>
                    </form>
                  </div>
                </div>
              </div>
              </div>

              <!-- COLUMNA DERECHA -->
              <div>
                <!-- STEPPER de progreso -->
                <div class="card">
                  <div class="card-head">Progreso del servicio</div>
                  <div class="card-body">
                    <%
                      const STEPS = [
                        {key:'pendiente',             label:'Solicitud creada',        sub:'Ticket generado'},
                        {key:'en_revision',           label:'Revisión inicial',         sub:'1-4 hs laborables'},
                        {key:'en_coordinacion',       label:'Coordinación de ingreso',  sub:'12-24 hs'},
                        {key:'en_recepcion',          label:'Recepción del dispositivo',sub:'15-30 min'},
                        {key:'en_diagnostico',        label:'En diagnóstico',           sub:'24-48 hs'},
                        {key:'esperando_aprobacion',  label:'Decisión del cliente',     sub:'1-3 días'},
                        {key:'en_reparacion',         label:'En reparación',            sub:'1-5 días'},
                        {key:'listo_para_retiro',     label:'Listo para retiro',        sub:'Coordiná pago'},
                        {key:'completado',            label:'Completado',               sub:'Servicio finalizado'},
                      ];
                      const ORDER = STEPS.map(s => s.key);
                      const curIdx = ORDER.indexOf(request.status);
                    %>
                      <div class="stepper">
                        <% STEPS.forEach((step, i)=> { %>
                          <% let cls='' ; if (i < curIdx) cls='done' ; else if (step.key===request.status) cls='active'
                            ; %>
                            <div class="step <%= cls %>">
                              <div class="step-dot">
                                <% if(cls==='done' ){ %><i class="fa-solid fa-check"></i>
                                  <% } else if(cls==='active' ){ %><i class="fa-solid fa-circle"
                                      style="font-size:0.5rem;"></i>
                                    <% } %>
                              </div>
                              <div>
                                <div class="step-label">
                                  <%= step.label %>
                                </div>
                                <div class="step-sub">
                                  <%= step.sub %>
                                </div>
                              </div>
                            </div>
                            <% }) %>
                      </div>
                  </div>
                </div>

                <!-- Historial -->
                <% if (history && history.length> 0) { %>
                  <div class="card">
                    <div class="card-head">Historial de cambios</div>
                    <div class="card-body" style="max-height:280px;overflow-y:auto">
                      <% history.forEach(h=> { %>
                        <div class="hist-item">
                          <div class="hist-dot"></div>
                          <div>
                            <div class="hist-label">
                              <%= h.notes || h.status %>
                            </div>
                            <div class="hist-time">
                              <%= new Date(h.created_at).toLocaleString('es-AR') %>
                            </div>
                          </div>
                        </div>
                        <% }) %>
                    </div>
                  </div>
                  <% } %>
              </div>
              </div>
  </main>

  <script>
    const reqId = <%= request.id %>;
  </script>
  <script src="/js/request-detail.js"></script>
</body>

</html>